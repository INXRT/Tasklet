// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  coins             Int       @default(0)
  karma             Int       @default(0)
  streak            Int       @default(0)
  lastActiveDate    String?
  activePokemonId   String?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  
  tasks             Task[]
  inventory         UserItem[]
  pokemons          UserPokemon[]
}

model UserPokemon {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  pokemonId   String   // The base species (e.g., "bulbasaur")
  xp          Int      @default(0)
  mood        String   @default("happy")
  isShiny     Boolean  @default(false)
  
  createdAt   DateTime @default(now())
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  
  isCompleted  Boolean   @default(false)
  dueDate      DateTime
  duration     Int       @default(60)
  urgency      String    @default("LOW")
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ShopItem {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Int
  type          String    // "food", "gacha"
  imageUrl      String?
  userItems     UserItem[]
}

model UserItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  
  @@unique([userId, shopItemId])
}
