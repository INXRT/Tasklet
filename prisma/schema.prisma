// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  coins             Int       @default(0)
  karma             Int       @default(0) // Determines evolution/level
  selectedCompanion String?   // "DRAGON", "GRIFFIN", "PHOENIX"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tasks             Task[]
  inventory         UserItem[]
}

model Task {
  id           String    @id @default(cuid())
  title        String
  description  String?
  
  // Custom logic
  isCompleted  Boolean   @default(false)
  dueDate      DateTime
  duration     Int       @default(60)
  urgency      String    @default("LOW")
  
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ShopItem {
  id            String    @id @default(cuid())
  name          String
  description   String?
  price         Int
  companionType String?   // If the item is specific to a companion
  imageUrl      String?
  userItems     UserItem[]
}

model UserItem {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id], onDelete: Cascade)
  isEquipped Boolean  @default(false)
  
  @@unique([userId, shopItemId])
}
